  set selection-clipboard clipboard
  set adjust-open "fit-width"
  set pages-per-row 1
  set scroll-page-aware "true"
  set smooth-scroll "true"
  set scroll-full-overlap 0.01
  set scroll-step 100
  set guioptions none

  set default-bg                  "#0f1010"
  set default-fg                  "#b9bfd2"

  set statusbar-fg                "#b9bfd2"
  set statusbar-bg                "#586EAF"

  set inputbar-bg                 "#0f1010"
  set inputbar-fg                 "#7891E3"

  set notification-bg             "#0f1010"
  set notification-fg             "#7891E3"

  set notification-error-bg       "#0f1010"
  set notification-error-fg       "#586EAF"

  set notification-warning-bg     "#0f1010"
  set notification-warning-fg     "#6477D0"

  set highlight-color             "#6B82BB"
  set highlight-active-color      "#6F89CF"

  set completion-bg               "#586EAF"
  set completion-fg               "#b9bfd2"

  set completion-highlight-fg     "#6F89CF"
  set completion-highlight-bg     "#586EAF"

  set recolor                     "true"
  set recolor-keephue             "false"
  set recolor-lightcolor          "#0f1010"
  set recolor-darkcolor           "#b9bfd2"
