 
# Fonts Settings

font-family = "MesloLGS Nerd Font Mono"
font-size = 16


# Mouse Settings
mouse-hide-while-typing = true


# keybindings
keybind = super+shift+r=reload_config

keybind = super+shift+w=close_surface


background-opacity = 0.8
background-blur = 50

window-padding-x = 10,5
window-padding-y = 10,5

# Theming Settings

theme = "tokyonight"

# For the theme to be well applied on the tabs
window-theme = ghostty
gtk-adwaita = true

resize-overlay = never
